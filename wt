#!/bin/bash
# wt — throwaway build sandboxes with instant zero-diff builds, via per-sandbox ZFS clones.
#
# Each sandbox is a git worktree that, inside its own mount namespace, appears at the SAME
# canonical path as your main checkout ($WT_CANONICAL) — but is a per-sandbox ZFS clone of it,
# build outputs and all. `zfs snapshot` + `zfs clone` take milliseconds, so `wt new` is fast and
# live: each sandbox clones main's CURRENT tree, with no warm-base step. Sandbox writes go to the
# clone (CoW from the snapshot); main and every other sandbox are untouched by construction.
#
# Because the sandbox lives at the SAME path as main and its sources and build outputs come
# from ONE atomic snapshot, their mtimes stay mutually consistent — so an mtime-based build
# system (cargo, make, ninja) sees a fully warm tree and rebuilds only what you actually edit.
# No content-hashing flag, no mtime-aging hack, no path remapping.
#
# Sandboxes share main's live `.git` via an in-namespace bind mount (the worktree-pointer
# mechanism), so branches made in a sandbox are visible from main and push the usual way. The
# command runs as a real uid (setuid, not a nested userns), so file ownership and capabilities
# are normal.
#
# WHAT wt DOES NOT KNOW: anything about your project. It has no language, toolchain, daemon or
# cache built in. Per-sandbox daemons and session env come from two HOOKS you configure:
#   WT_HOOK_ENTER     runs in the sandbox namespace as the target user, once per `wt enter`,
#                     before the command is exec'd. Its exit code GATES the session: non-zero
#                     aborts, because a session that starts without what the hook guarantees
#                     (say, a per-sandbox daemon socket) silently falls back to a shared one and
#                     writes this sandbox's build outputs into another's. Make advisory steps
#                     `|| true`. stdout is the env channel: KEY=VALUE lines are exported into
#                     the session (direnv-style). stderr goes to your terminal.
#   WT_HOOK_TEARDOWN  runs host-side when a sandbox's resources must be released: the LAST
#                     session exiting, `wt rm`, and `wt gc`. Its exit code is IGNORED (a broken
#                     teardown hook must not make a sandbox unremovable) and it must be
#                     idempotent. Anything the enter hook left running inside the namespace pins
#                     the clone's mount and would otherwise block `zfs destroy`.
#
# Config: $WT_CONFIG, else ~/.config/wt/config, else /etc/wt/config; environment overrides the
# file. See wt.conf.example. Prerequisite: the host owner ran host-zfs-setup.sh once, to build
# the datasets and zfs-delegate snapshot/clone/destroy/mount to the target user.
#
# Sandbox commands (in a devcontainer install, run these inside the container):
#   wt new   <name> [ref]         snapshot+clone main's tree, register git worktree pointer
#   wt enter <name> [-- cmd...]   enter the sandbox (default: bash)
#   wt list                       list sandboxes + the bytes each clone alone is holding down
#   wt rm    <name>               clone+snapshot destroyed; branch archived to wt-archive/<name>
#   wt gc                         reclaim orphan snapshots/clones whose sandbox is gone
#   wt status                     show config + dataset state
#
# SSH plumbing. You run ssh-setup once (from the container's start hook); `wt-ssh` and sshd call
# the rest:
#   wt ssh-setup                  write $WT_SSH_DIR sshd config + authorized_keys   <- YOU, once
#   wt ssh-config [repo]          emit ~/.ssh/config blocks          <- `wt-ssh config`
#   wt ssh-serve  <name>          inetd sshd entry over docker exec  <- `wt-ssh proxy <name>`
#   wt ssh-forced                 sshd ForceCommand -> wt enter <name>
set -euo pipefail

# wt-setup.sh is wt's neighbour in the checkout. readlink -f resolves an install symlink back to
# the real file, so SELF_DIR lands next to wt-setup.sh wherever wt itself was installed from.
SELF_DIR=$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)

die() { echo "wt: $*" >&2; exit 1; }
log() { echo "wt: $*" >&2; }

# ---- config ------------------------------------------------------------------------------
# Precedence: environment > config file > built-in default.
#
# The config file is SOURCED (it is shell), so it may compute values. Whatever it sets is then
# overridden by anything that was already in the environment — that is what the `export -p`
# snapshot below restores. Searched, unless $WT_CONFIG names a file outright:
#     $XDG_CONFIG_HOME/wt/config   (default ~/.config/wt/config)
#     /etc/wt/config
# WT_CONFIG= (explicitly empty) skips the file entirely. The unit tests set that, so a stray
# /etc/wt/config on the machine cannot reach in and change their answers.
_wt_env=$(export -p | grep -E '^declare -x WT_[A-Za-z0-9_]+=' || true)
if [ -z "${WT_CONFIG+x}" ]; then
  for _c in "${XDG_CONFIG_HOME:-$HOME/.config}/wt/config" /etc/wt/config; do
    [ -r "$_c" ] && { WT_CONFIG=$_c; break; }
  done
fi
if [ -n "${WT_CONFIG:-}" ]; then
  [ -r "$WT_CONFIG" ] || die "config file not readable: $WT_CONFIG"
  # shellcheck source=/dev/null
  . "$WT_CONFIG"
  eval "$_wt_env"        # environment wins over the file
fi

# The checkout wt clones. No sensible default — an install must declare it.
WT_CANONICAL=${WT_CANONICAL:-}

# Sandbox state (trees/, meta/, active/, locks/). On the host, outside every clone.
WT_HOME=${WT_HOME:-${XDG_DATA_HOME:-$HOME/.local/share}/wt}

# The ZFS datasets behind WT_CANONICAL and WT_HOME (made by host-zfs-setup.sh). When unset,
# default to the ZFS dataset each is mounted from — so an install that bind-mounts both onto
# ZFS need not repeat the names in its config. Empty when the mount isn't ZFS; require_config()
# then reports the same "not set" error as before, so a non-ZFS install sees no regression.
_wt_zfs_at() { findmnt -no SOURCE,FSTYPE -T "${1:-/nonexistent}" 2>/dev/null | awk '$2=="zfs"{print $1}' || true; }
WT_DS_SRC=${WT_DS_SRC:-$(_wt_zfs_at "$WT_CANONICAL")}
WT_DS_PARENT=${WT_DS_PARENT:-$(_wt_zfs_at "$WT_HOME")}
unset -f _wt_zfs_at

# Subpaths of the checkout that must NOT be captured in snapshots. Each is its own ZFS child
# dataset — never snapshotted, so absent from clones — and is bind-mounted through from the
# canonical checkout, so every sandbox shares one live copy on the host. Space-separated,
# relative to WT_CANONICAL.
WT_SNAPSHOT_EXCLUDE=${WT_SNAPSHOT_EXCLUDE:-}

# ZFS user property stamped on every snapshot wt takes. `wt gc` reaps — and `wt list` classifies
# as reclaimable — ONLY snapshots carrying it, so a hand-made @wt-* snapshot is never destroyed
# on the strength of its name.
WT_ZFS_PROP=${WT_ZFS_PROP:-com.wt:managed}

# uid/gid the sandbox command runs as. wt needs root only to mount the clone, never to run
# your shell. Defaults to whoever invoked wt — but pin it in config if wt is ever invoked as
# root (`wt ssh-serve` is), since `id -u` would then be 0.
WT_TARGET_UID=${WT_TARGET_UID:-$(id -u)}
WT_TARGET_GID=${WT_TARGET_GID:-$(id -g)}
WT_TARGET_USER=${WT_TARGET_USER:-$(id -nu "$WT_TARGET_UID" 2>/dev/null || echo "$WT_TARGET_UID")}

# ns-local hold paths: bind targets that keep main's live .git and the excluded subpaths
# reachable after the clone is mounted over WT_CANONICAL (see wt-setup.sh).
WT_GIT_HOLD=${WT_GIT_HOLD:-/tmp/wt-git-main}
WT_HOLD_DIR=${WT_HOLD_DIR:-/tmp/wt-holds}

# ---- session hooks (see header) ----------------------------------------------------------
# wt ships with NO hooks: it has no opinion about what a sandbox should run. The consuming
# project supplies them from its config file.
WT_HOOK_ENTER=${WT_HOOK_ENTER:-}
WT_HOOK_TEARDOWN=${WT_HOOK_TEARDOWN:-}

# ---- optional ssh transport (see wt-ssh) -------------------------------------------------
WT_SSH_DIR=${WT_SSH_DIR:-$HOME/.wt-ssh}            # inetd sshd config + authorized_keys
WT_SSH_PROXY=${WT_SSH_PROXY:-wt-ssh}               # ProxyCommand path, relative to the checkout
WT_REMOTE_BIN=${WT_REMOTE_BIN:-/usr/local/bin/wt}  # wt's path inside the container
# If your container mounts the host's ssh agent, name its socket here and sandbox sessions
# opened over `wt-ssh` inherit it, so git/ssh out of a sandbox works. Empty: leave SSH_AUTH_SOCK
# to whatever sshd set up.
WT_SSH_AGENT_SOCK=${WT_SSH_AGENT_SOCK:-}

# Commands that touch datasets need a real config; `wt help` does not.
require_config() {
  [ -n "$WT_CANONICAL" ] || die "WT_CANONICAL is not set (config: ${WT_CONFIG:-none found}) — see wt.conf.example"
  [ -n "$WT_DS_SRC" ]    || die "WT_DS_SRC is not set (config: ${WT_CONFIG:-none found}) — see wt.conf.example"
  [ -n "$WT_DS_PARENT" ] || die "WT_DS_PARENT is not set (config: ${WT_CONFIG:-none found}) — see wt.conf.example"
  # The two datasets must be DISJOINT, and it matters in both directions. `wt gc` destroys the
  # children of $WT_DS_PARENT and reads $WT_DS_SRC's snapshots; nest either inside the other and
  # gc walks into the wrong tree. With the source under the parent, gc enumerates $WT_DS_SRC's
  # WT_SNAPSHOT_EXCLUDE children as "orphan clones" and destroys them — and those hold the only,
  # never-snapshotted copy of that data. host-zfs-setup.sh refuses the same two layouts.
  case "$WT_DS_PARENT" in
    "$WT_DS_SRC"|"$WT_DS_SRC"/*)
      die "WT_DS_PARENT ($WT_DS_PARENT) must not be, or live under, WT_DS_SRC ($WT_DS_SRC)" ;;
  esac
  case "$WT_DS_SRC" in
    "$WT_DS_PARENT"/*)
      die "WT_DS_SRC ($WT_DS_SRC) must not live under WT_DS_PARENT ($WT_DS_PARENT)" ;;
  esac
}

# Remove a path only if it's under WT_HOME (defends against empty/typo vars).
safe_rmrf() {
  local p=${1:-}
  [ -n "$p" ] || die "safe_rmrf: empty path"
  case "$p" in "$WT_HOME"/*) : ;; *) die "safe_rmrf: refusing path outside $WT_HOME: $p" ;; esac
  chmod -R u+rwx -- "$p" 2>/dev/null || true
  rm -rf -- "$p"
}

# A sandbox name ends up in a dataset path, a snapshot name, a branch name, a marker filename and
# an `rm -rf` argument. Restrict it to one character class up front, with no leading dash, so no
# consumer downstream can parse it as a flag or reject it halfway through `wt new` — which would
# leave the snapshot and worktree already made and needing cleanup by hand.
validate_name() { case "${1:-}" in ''|-*|*[!a-zA-Z0-9_-]*) die "invalid sandbox name: '${1:-}'";; esac; }

# Flatten an excluded subpath ("build/logs") into one hold-dir component ("build_Slogs").
#
# The encoding must be INJECTIVE, or two excluded subpaths can land on the same hold path — and
# then wt-setup.sh binds the second one's live data over BOTH of them inside the sandbox, so
# writes meant for one shared directory silently land in the other. Escaping only '/' does not
# achieve that: a real directory named "build_Slogs" would collide with the subpath "build/logs".
# So escape the escape character first, then the separator:
#     _ -> _U       /  -> _S
# wt-setup.sh defines this identically; test-config-unit.sh asserts the two agree.
exclude_key() { local s=${1//_/_U}; printf '%s' "${s//\//_S}"; }

# --- session liveness ---------------------------------------------------------------------
# $WT_HOME lives on persistent storage and the EXIT trap never runs on SIGKILL (OOM kill,
# `docker kill`, host crash), so a marker file's existence proves nothing. A session is live only
# while its creator still holds an exclusive flock on the marker; the lock dies with the process,
# whatever kills it.
#
# Which makes an inherited fd the one way to fake liveness — a daemon that inherits the open
# marker holds the lock long after the session is gone. sudo's closefrom(3) would drop it anyway,
# but the closes are explicit (`9>&-` into the sandbox, `8>&-` into the teardown hook) rather than
# a bet on how someone's sudoers is configured.
WT_LOCK_DIR=$WT_HOME/locks

# Serialize new/rm/enter for one sandbox, so `wt rm` can't sample "not in use" in the window
# before a concurrent `wt enter` has published its marker.
lock_name() {
  mkdir -p "$WT_LOCK_DIR"
  exec 8>"$WT_LOCK_DIR/$1.lock"
  flock -w 60 8 || die "timed out waiting for another wt command on '$1'"
}
unlock_name() { exec 8>&-; }

# Is a session still holding this marker's lock?
#
# Open the marker READ-ONLY and lock that fd. `flock <path> ...` would open the path with O_CREAT,
# so the probe would CREATE the very marker it is asking about — resurrecting, as an empty stale
# marker, one that an exiting session had just removed. A predicate must not write.
# (LOCK_EX on a read-only fd is fine: flock(2) locks the open file description, not the access
# mode. That is not true of fcntl locks, which is the trap this looks like.)
# The redirects hang off a COMPOUND, never off a bare `exec`: `exec 7<f 2>/dev/null` would make
# BOTH permanent for the whole shell, silencing wt's own stderr for the rest of the run. And
# 2>/dev/null comes FIRST, so a failed open is quiet — redirections are applied left to right.
# The fd, and with it the lock, is released when the compound finishes.
marker_live() {
  local got=1
  { if flock -n -x 7; then got=0; fi; } 2>/dev/null 7<"$1" || return 1  # gone: no session holds it
  [ "$got" -eq 0 ] && return 1                                          # we took it: nobody had it
  return 0
}

name_active() {
  local m
  for m in "$WT_HOME"/active/"$1".*; do
    marker_live "$m" && return 0
  done
  return 1
}

# Drop markers whose session is gone. Callers hold the sandbox's name lock, so this cannot
# race a session that has created its marker but not yet locked it.
prune_stale_markers() {
  local m
  for m in "$WT_HOME"/active/"$1".*; do
    [ -e "$m" ] || continue
    marker_live "$m" || { log "pruning stale session marker ${m##*/}"; rm -f -- "$m"; }
  done
}

# Release a sandbox's per-session resources by firing the teardown hook (host-side). Whatever
# daemons the enter hook started, the teardown hook stops; wt does not know what they are. The
# contract is best-effort and idempotent — this may be called when nothing is running, and a
# missing or failing hook must never fail the wt operation that called it (a sandbox whose hook
# is broken must still be removable).
#
# 8>&- keeps the caller's name-lock fd out of the hook. `wt rm` holds that lock across this call,
# and anything the hook daemonizes would inherit the fd and hold the lock after wt exits — every
# later wt command on that name would then block for 60s and die, with no process to blame.
run_teardown_hook() {
  local n=$1
  [ -n "${WT_HOOK_TEARDOWN:-}" ] || return 0
  WT_SANDBOX="$n" bash -c "$WT_HOOK_TEARDOWN" >/dev/null 2>&1 8>&- || true
}

# `wt enter`'s EXIT trap. Drop our marker, and if we were the LAST session for this sandbox, fire
# the teardown hook: a daemon the enter hook started (a build cache, a language server — wt
# doesn't know) keeps the clone's mount namespace alive indefinitely, and a pinned clone cannot
# be destroyed.
#
# Under the name lock, because the decision and the teardown must not straddle a new session. The
# everyday case is an editor reconnecting: our last session dies as the next one opens. Unlocked,
# we could find no live marker, and then run teardown just as the NEW session's enter hook
# finishes starting its daemons — stopping the daemons of a session that is about to use them.
# Holding the lock forces the two to order: either the new session's marker is published (we see
# it and skip), or it waits for our teardown before it starts anything.
#
# The lock is best-effort: a shell exiting is not a place to hang. The hook is idempotent, so the
# worst case of proceeding without it is a duplicate call.
_wt_session_name=""; _wt_session_marker=""
on_session_exit() {
  rm -f -- "$_wt_session_marker"
  mkdir -p "$WT_LOCK_DIR"
  exec 8>"$WT_LOCK_DIR/$_wt_session_name.lock"
  flock -w 30 8 || log "exit: timed out on the '$_wt_session_name' lock; tearing down anyway"
  name_active "$_wt_session_name" || run_teardown_hook "$_wt_session_name"
  exec 8>&-
}

# Kill any process whose mount namespace still has $1 (a clone dataset) mounted — e.g. a
# daemonized IDE server that outlived its ssh session — so `zfs destroy` isn't blocked.
# Reading another namespace/owner's mountinfo needs root, hence sudo.
#
# The match is anchored to mountinfo's mount-source field (the second field after the `-`
# separator; see proc_pid_mountinfo(5)), not the whole line: a mount whose mount-POINT path
# merely ends in the dataset name must not earn its namespace a SIGTERM.
kill_clone_holders() {
  local clone=$1 p
  for p in /proc/[0-9]*; do
    p=${p#/proc/}
    if sudo awk -v c="$clone" '
         { for (i = 7; i <= NF; i++) if ($i == "-") { if ($(i+2) == c) found = 1; break } }
         END { exit !found }
       ' "/proc/$p/mountinfo" 2>/dev/null; then
      log "killing lingering holder pid $p (clone $clone still mounted)"
      sudo kill -TERM "$p" 2>/dev/null || true
    fi
  done
}

tree=""; meta=""
set_paths() { tree=$WT_HOME/trees/$1; meta=$WT_HOME/meta/$1; }

git_common_dir_abs() { ( cd "$WT_CANONICAL" && realpath "$(git rev-parse --git-common-dir)" ); }

require_zfs() {
  command -v zfs >/dev/null 2>&1 || die "zfs CLI not found (install zfsutils-linux)"
  local ds
  for ds in "$WT_DS_SRC" "$WT_DS_PARENT"; do
    zfs list -H -o name "$ds" >/dev/null 2>&1 \
      || die "dataset $ds does not exist — run host-zfs-setup.sh on the host"
  done
}

# ---- subcommands ------------------------------------------------------------------------
wt_new() {
  local name=${1:?usage: wt new <name> [ref]} ref=${2:-HEAD}
  # Refuse from inside a sandbox: the snapshot/clone would come from MAIN's datasets while the
  # branch, ref_sha and seeded index come from THIS sandbox's HEAD — a worktree that registers
  # durably and looks valid, but whose files are main's tree with this sandbox's baseline, so
  # `git status` shows a huge spurious diff and this sandbox's work is silently absent. To fork
  # a sandbox: commit in it (wt/<name> is visible from main via the shared .git), then from
  # main run `wt new <other> wt/<name>`.
  [ -z "${WT_SANDBOX:-}" ] \
    || die "wt new cannot run inside a sandbox (you are in '$WT_SANDBOX') — run it from main"
  require_config; validate_name "$name"; set_paths "$name"; require_zfs

  mkdir -p "$WT_HOME"/{trees,meta,active}
  # Two `wt new <same-name>` would otherwise both pass the existence checks and collide on the
  # snapshot name, leaving a half-registered worktree behind.
  lock_name "$name"
  [ -e "$tree" ] && die "sandbox '$name' already exists"
  zfs list -H -o name "$WT_DS_PARENT/$name" >/dev/null 2>&1 \
    && die "ZFS clone $WT_DS_PARENT/$name already exists (run 'wt rm $name' or 'wt gc')"

  # Warn, don't refuse: the snapshot captures main's dirty working tree while the sandbox branch
  # points at $ref, so `git status` in the sandbox shows main's uncommitted changes as its own
  # diff. Sometimes what you want, so say it out loud rather than choose for the user.
  local dirty count
  dirty=$(git -C "$WT_CANONICAL" status --porcelain 2>/dev/null || true)
  if [ -n "$dirty" ]; then
    count=$(printf '%s\n' "$dirty" | wc -l)
    log "main is dirty ($count uncommitted file(s)); sandbox '$name' will inherit them as working-tree diff:"
    printf '%s\n' "$dirty" | head -5 | sed 's/^/  /' >&2
    [ "$count" -gt 5 ] && echo "  ... and $((count-5)) more" >&2
  fi

  # Register the worktree BEFORE snapshotting, and pin $ref to a SHA first: if main checks out a
  # different branch mid-flight, worktree HEAD and snapshot still agree on one commit.
  # --no-checkout writes no source files — the clone supplies them. git writes only the $tree/.git
  # placeholder and main-side bookkeeping under $main/.git/worktrees/<name>/, which lives in the
  # source dataset and so lands in the snapshot below; wt-setup.sh masks it in-namespace by
  # binding main's live .git over it.
  local ref_sha src_commit
  ref_sha=$(git -C "$WT_CANONICAL" rev-parse --verify "$ref^{commit}") \
    || die "could not resolve ref '$ref'"
  mkdir -p "$tree"
  git -C "$WT_CANONICAL" worktree add --no-checkout -b "wt/$name" "$tree" "$ref_sha"

  # The baseline commit the snapshot's files correspond to. Read as late as possible — right
  # before the seed/snapshot, after the slow worktree registration — because a commit landing on
  # main between this read and the snapshot makes meta/src_commit name a staler baseline than the
  # snapshot's bytes, which costs the non-HEAD materialization path its cheap read-tree and some
  # build warmth.
  src_commit=$(git -C "$WT_CANONICAL" rev-parse --verify HEAD)

  # Seed the index. git judges cleanliness working-tree-vs-INDEX (then index-vs-HEAD), and
  # --no-checkout leaves the index empty — without this, every file the clone provides reads as
  # both a staged deletion and untracked. read-tree writes the index only. Skipped when $ref is
  # not main's current checkout: those files aren't in the snapshot, so wt-setup.sh materializes
  # them on first enter, where the clone is writable.
  if [ "$ref_sha" = "$src_commit" ]; then
    git -C "$tree" read-tree "$ref_sha"
  fi

  # Snapshot the parent dataset only: no -r, so the WT_SNAPSHOT_EXCLUDE child datasets stay out,
  # which is exactly why they never reach a clone. $WT_ZFS_PROP=1 is provenance — gc and list
  # filter on it, so nothing wt didn't create is ever auto-reaped.
  local snap
  snap="$WT_DS_SRC@wt-$name-$(date +%Y%m%d-%H%M%S)"
  zfs snapshot -o "$WT_ZFS_PROP=1" "$snap"

  # mountpoint=legacy: wt owns the mount lifecycle, and the clone is only ever mounted inside a
  # sandbox namespace. canmount=noauto: a stray `zfs mount -a` must not surface it on the host.
  zfs clone -o mountpoint=legacy -o canmount=noauto "$snap" "$WT_DS_PARENT/$name"

  # Per-sandbox metadata. wt-setup.sh uses dot_git to replace the snapshot-frozen (and inert)
  # .git directory inside the clone.
  mkdir -p "$meta"
  echo "$snap"               > "$meta/snapshot"
  echo "$WT_DS_PARENT/$name" > "$meta/clone"
  # Baseline commit the snapshot's files correspond to, and the branch HEAD the sandbox should
  # land on. wt-setup.sh uses them to materialize a non-HEAD ref into the clone on first enter.
  echo "$src_commit"         > "$meta/src_commit"
  echo "$ref_sha"            > "$meta/ref_sha"
  printf 'gitdir: %s/worktrees/%s\n' "$WT_GIT_HOLD" "$name" > "$meta/dot_git"
  printf '%s/.git\n'                 "$WT_CANONICAL" > "$meta/gitdir_backptr"

  log "created sandbox '$name' (branch wt/$name @ $ref_sha, clone $WT_DS_PARENT/$name)"
}

wt_enter() {
  local name=${1:?usage: wt enter <name> [-- cmd...]}; shift || true
  require_config; validate_name "$name"; set_paths "$name"
  [ "${1:-}" = -- ] && shift || true

  local -a cmd=( "$@" ); [ ${#cmd[@]} -eq 0 ] && cmd=( bash )
  # Hold paths for the excluded subpaths are made here (as the user) rather than in-NS, so
  # they exist on the host before the mount namespace is unshared.
  mkdir -p "$WT_HOME/active" "$WT_GIT_HOLD" "$WT_HOLD_DIR"
  local _sub
  for _sub in $WT_SNAPSHOT_EXCLUDE; do mkdir -p "$WT_HOLD_DIR/$(exclude_key "$_sub")"; done

  # Publish this session before releasing the lock: a `wt rm` that starts now blocks here,
  # then sees a live marker, rather than destroying the clone this session is about to mount.
  lock_name "$name"
  prune_stale_markers "$name"
  [ -d "$tree" ] || { unlock_name; die "no sandbox '$name' — run 'wt new $name'"; }
  local clone; clone=$(cat "$meta/clone" 2>/dev/null) \
    || { unlock_name; die "sandbox '$name' has no clone recorded"; }
  zfs list -H -o name "$clone" >/dev/null 2>&1 \
    || { unlock_name; die "ZFS clone '$clone' missing — sandbox state is corrupt; 'wt rm $name' then recreate"; }

  local active="$WT_HOME/active/$name.$$"
  exec 9>"$active"
  flock -n 9 || die "internal: fresh session marker $active is already locked"
  unlock_name

  # The EXIT trap fires after wt_enter has returned, so its locals are gone by then — the session
  # identity has to outlive the frame.
  _wt_session_name=$name
  _wt_session_marker=$active
  trap on_session_exit EXIT

  # Everything wt-setup.sh needs, across the `sudo -E` boundary. WT_HOOK_ENTER rides along so
  # setup can fire it after the privilege drop. Nothing here is language- or project-specific:
  # a consuming project injects its own session env (cargo jobs, caches, ...) via that hook.
  # WT_PATH carries our PATH across sudo, whose secure_path would otherwise strip the caller's
  # toolchains even under -E; wt has no idea what is on it, wt-setup.sh just puts it back.
  # Computed before the export, not inside it: `export FOO=$(f)` throws away f's exit status, so a
  # git that failed here would sail through as an empty WT_GIT_REAL and only be caught in-namespace.
  local git_real src_commit ref_sha
  git_real=$(git_common_dir_abs) \
    || die "could not resolve main's git dir under $WT_CANONICAL"
  src_commit=$(cat "$meta/src_commit" 2>/dev/null || true)
  ref_sha=$(cat "$meta/ref_sha" 2>/dev/null || true)

  export WT_CANONICAL WT_SRC_CLONE="$clone" WT_META="$meta" \
         WT_GIT_HOLD WT_GIT_REAL="$git_real" \
         WT_HOLD_DIR WT_SNAPSHOT_EXCLUDE WT_TARGET_UID WT_TARGET_GID \
         WT_SANDBOX="$name" WT_HOOK_ENTER WT_PATH="$PATH" \
         WT_SRC_COMMIT="$src_commit" WT_REF_SHA="$ref_sha"

  # Mounting a delegated dataset needs REAL CAP_SYS_ADMIN: the ZFS module rejects the mount from
  # a non-init userns even with `zfs allow mount`, so a userns alone will not do. Hence sudo for
  # the mount namespace, mounts as root, then a setuid drop in wt-setup.sh. The namespace dies
  # with this process tree, so the ZFS mount cleans itself up on exit.
  #
  # 9>&- keeps the marker's lock fd out of the sandbox. Whatever the enter hook starts daemonizes
  # in there, and an inherited fd would hold the marker "live" long after the session ended.
  #
  # WT_DROP_PRIV is wt-setup.sh's test seam for skipping the privilege drop, and `sudo -E` would
  # carry it across from the caller's environment. Then the sandbox command would run as root,
  # against main's bind-mounted live .git and the shared excluded subpaths — root-owned objects in
  # the real repo. Nothing in a real session sets it, so drop it here and leave the seam reachable
  # only by sourcing wt-setup.sh directly, which is what the tests do.
  unset WT_DROP_PRIV
  sudo -E unshare --mount --propagation private -- \
    "$SELF_DIR/wt-setup.sh" "$name" -- "${cmd[@]}" 9>&-
}

wt_list() {
  require_config
  [ -d "$WT_HOME/trees" ] || { echo "(no sandboxes)"; return 0; }
  local d name br act f used here orphans untagged s sn tag; set +e
  here=${WT_SANDBOX:-}
  # Header.
  printf '%-2s %-16s  %-22s  %-10s  %s\n' '*' 'NAME' 'BRANCH' 'USED' 'ACTIVE'
  for d in "$WT_HOME"/trees/*/; do
    [ -d "$d" ] || continue
    name=$(basename "$d")
    # The branch wt new CREATED, not necessarily the sandbox's current HEAD — a sandbox can check
    # out anything. Named by construction to avoid a git lookup, which fails from inside a sandbox.
    br="wt/$name"
    used=$(zfs get -H -o value used "$WT_DS_PARENT/$name" 2>/dev/null); [ -n "$used" ] || used='?'
    # Count sessions, not marker files: a SIGKILLed session leaves its marker behind.
    act=0; for f in "$WT_HOME"/active/"$name".*; do marker_live "$f" && act=$((act+1)); done
    # '*' marks the sandbox you are currently inside.
    printf '%-2s %-16s  %-22s  %-10s  %s\n' \
      "$([ "$name" = "$here" ] && echo '*' || echo ' ')" \
      "$name" "$br" "$used" "$([ "$act" -gt 0 ] && echo "yes ($act)" || echo '-')"
  done
  set -e
  # Surface orphan @wt-* snapshots that don't match a current sandbox tree. Split by provenance:
  # only wt-tagged ($WT_ZFS_PROP=1) ones are gc's to reclaim; untagged @wt-* snapshots gc
  # leaves alone, so list them separately or they'd silently pile up unnoticed.
  orphans=; untagged=
  while IFS= read -r s; do
    [ -n "$s" ] || continue
    sn=${s#*@wt-}; sn=${sn%-*-*}        # strip trailing -YYYYMMDD-HHMMSS
    [ -d "$WT_HOME/trees/$sn" ] && continue
    # || true: a snapshot listed a moment ago can be destroyed by a concurrent wt rm before we
    # get to it. Without it, `set -e` would kill the loop from the inside and truncate the table.
    tag=$(zfs get -H -o value "$WT_ZFS_PROP" "$s" 2>/dev/null || true)
    if [ "$tag" = 1 ]; then orphans+="$s"$'\n'; else untagged+="$s"$'\n'; fi
  done < <(zfs list -H -o name -t snapshot "$WT_DS_SRC" 2>/dev/null | grep -E '@wt-' || true)
  if [ -n "$orphans" ]; then
    echo
    echo "orphan snapshots (run 'wt gc' to reclaim):"
    printf '  %s\n' "$orphans" | sed '/^  $/d'
  fi
  if [ -n "$untagged" ]; then
    echo
    echo "untagged @wt-* snapshots (not wt-managed — reap by hand):"
    printf '  %s\n' "$untagged" | sed '/^  $/d'
  fi
  return 0
}

wt_gc() {
  require_config          # enforces that the two datasets are disjoint, which everything below relies on
  command -v zfs >/dev/null 2>&1 || return 0

  # Stale session markers: enter and rm each prune their own sandbox's on the way in, but a
  # sandbox nobody touches again keeps its dead markers forever. This is the only sweep of all of
  # them.
  local m n
  for m in "$WT_HOME"/active/*; do
    [ -e "$m" ] || continue
    n=${m##*/}; n=${n%.*}
    case "$n" in ''|-*|*[!a-zA-Z0-9_-]*) continue ;; esac
    lock_name "$n"; prune_stale_markers "$n"; unlock_name
  done

  # Orphan clones: children of $WT_DS_PARENT whose $WT_HOME/trees/<name> is gone. -d 1, not -r:
  # only a direct child of the parent is a sandbox clone. A dataset someone created *inside* a
  # clone is that sandbox's business, and reaping it on the strength of its basename would be a
  # coincidence, not a decision.
  local clone bn
  while IFS= read -r clone; do
    [ -n "$clone" ] || continue
    bn=${clone##*/}
    if [ ! -d "$WT_HOME/trees/$bn" ]; then
      run_teardown_hook "$bn"   # release the clone mount a leftover session daemon would pin
      log "gc: destroying orphan clone $clone"
      zfs destroy "$clone" 2>/dev/null || log "  (failed; still mounted?)"
    fi
  done < <(zfs list -H -o name -d 1 "$WT_DS_PARENT" 2>/dev/null | tail -n +2)

  # Orphan snapshots: @wt-* on $WT_DS_SRC that wt created ($WT_ZFS_PROP=1) AND that no clone
  # references AND whose sandbox tree is gone. All three matter. Provenance, because a name glob
  # can't prove it — an untagged @wt-* (hand-made, or another tool's) is left alone. The tree
  # check, because `wt new` stamps its snapshot BEFORE it makes the clone: for that instant the
  # snapshot is tagged and clone-less, which is exactly this loop's reap predicate. `wt new`
  # creates trees/<name> before either, so the tree is what proves a sandbox is being born rather
  # than long dead. (`wt list` splits the same three ways; keep the two in step.)
  local snap tag clones_of sn
  while IFS= read -r snap; do
    [ -n "$snap" ] || continue
    sn=${snap#*@wt-}; sn=${sn%-*-*}     # strip trailing -YYYYMMDD-HHMMSS
    [ -d "$WT_HOME/trees/$sn" ] && continue
    # || true on both: a concurrent `wt rm` can destroy a snapshot between the listing above and
    # the query here. Bare, `set -e` would kill gc from inside the loop — and with stderr sent to
    # /dev/null, a cron'd gc would just silently stop reclaiming.
    tag=$(zfs get -H -o value "$WT_ZFS_PROP" "$snap" 2>/dev/null || true)
    if [ "$tag" != 1 ]; then
      log "gc: skipping untagged snapshot $snap (not wt-managed)"
      continue
    fi
    clones_of=$(zfs get -H -o value clones "$snap" 2>/dev/null || true)
    if [ -z "$clones_of" ] || [ "$clones_of" = '-' ]; then
      log "gc: destroying orphan snapshot $snap"
      zfs destroy "$snap" 2>/dev/null || log "  (failed)"
    fi
  done < <(zfs list -H -o name -t snapshot "$WT_DS_SRC" 2>/dev/null | grep -E '@wt-' || true)
}

wt_rm() {
  local name=${1:?usage: wt rm <name>}; require_config; validate_name "$name"; set_paths "$name"
  # Held for the whole removal: a `wt enter` racing us blocks, then finds the tree gone.
  lock_name "$name"
  prune_stale_markers "$name"
  name_active "$name" && die "sandbox '$name' is in use; exit it first"

  # Without this, `wt rm scna` (a typo for `scan`) no-ops every step below and still reports
  # "removed sandbox 'scna'" — and the real sandbox keeps holding down the pool while the user
  # believes they just reclaimed it. A clone with no tree is still a sandbox to remove, so accept
  # any evidence of one.
  [ -d "$tree" ] || [ -d "$meta" ] || zfs list -H -o name "$WT_DS_PARENT/$name" >/dev/null 2>&1 \
    || die "no sandbox '$name' (nothing to remove)"

  local clone snap
  clone=$(cat "$meta/clone" 2>/dev/null || true)
  snap=$(cat "$meta/snapshot" 2>/dev/null || true)
  # A tree removed by hand leaves the clone unrecorded but still real; name it by construction so
  # the destroy below can still find it.
  [ -n "$clone" ] || clone="$WT_DS_PARENT/$name"

  # A snapshot or child dataset under the clone (wt never creates either — it only snapshots
  # WT_DS_SRC) defeats `zfs destroy` on every attempt: the retry loop below would burn its full
  # ~15s, kill mount-holders that are not the blocker, and only then surface ZFS's real error.
  # It is user-made data, so refuse up front — before the tree, metadata or branch are touched —
  # and name it. Never destroy it with -R on the user's behalf.
  if zfs list -H -o name "$clone" >/dev/null 2>&1; then
    local deps
    deps=$( { zfs list -H -o name -t snapshot -d 1 "$clone" 2>/dev/null; \
              zfs list -H -o name -d 1 "$clone" 2>/dev/null | tail -n +2; } | sed '/^$/d' )
    [ -z "$deps" ] || die "clone $clone has dependents; destroy them first:
$deps"
  fi

  [ -d "$tree" ] && { git -C "$WT_CANONICAL" worktree remove --force "$tree" 2>/dev/null || true; }
  safe_rmrf "$meta"; safe_rmrf "$tree"
  git -C "$WT_CANONICAL" worktree prune 2>/dev/null || true
  # Preserve unmerged work: rename the branch to a predictable, deconflicted archive
  # instead of deleting it (the worktree was removed just above, so the branch is free).
  if git -C "$WT_CANONICAL" show-ref --verify --quiet "refs/heads/wt/$name"; then
    local archive="wt-archive/$name"
    if git -C "$WT_CANONICAL" show-ref --verify --quiet "refs/heads/$archive"; then
      archive="wt-archive/$name-$(date +%Y%m%d-%H%M%S)"
    fi
    if git -C "$WT_CANONICAL" branch -m "wt/$name" "$archive" 2>/dev/null; then
      log "archived branch wt/$name -> $archive (delete it manually when the work is safe)"
    else
      log "could not archive branch wt/$name; left in place"
    fi
  fi

  # A lingering session daemon keeps the clone mounted (see run_teardown_hook); stop it so the
  # destroy below isn't blocked by a busy dataset. The teardown is signal-based and the kernel
  # takes a moment to reap the mount namespace, so we retry the destroy a few times if it fails.
  run_teardown_hook "$name"

  # Destroy clone first (snapshot has the clone as a dependency). After the sandbox's
  # mount namespace is torn down, ZFS takes a few seconds to release its internal hold on
  # the dataset (the namespace death is async wrt zfs destroy). Retry for ~15s before
  # giving up — this is invisible to the user when there's no race.
  if [ -n "$clone" ] && zfs list -H -o name "$clone" >/dev/null 2>&1; then
    local attempt=0 killed=0
    while ! zfs destroy "$clone" 2>/dev/null; do
      attempt=$((attempt + 1))
      # After a few seconds of a busy clone, a process is pinning it — kill holders once.
      if [ "$killed" -eq 0 ] && [ "$attempt" -ge 6 ]; then
        kill_clone_holders "$clone"; killed=1
      fi
      if [ "$attempt" -ge 30 ]; then
        zfs destroy "$clone" || die "zfs destroy $clone failed after 30 retries (still mounted? promoted?)"
        break
      fi
      sleep 0.5
    done
  fi
  if [ -n "$snap" ] && zfs list -H -o name -t snapshot "$snap" >/dev/null 2>&1; then
    zfs destroy "$snap" 2>/dev/null || log "snap $snap still referenced; left in place"
  fi

  log "removed sandbox '$name'"
}

wt_status() {
  [ -n "${WT_SANDBOX:-}" ] && echo "current       : $WT_SANDBOX  (you are inside this sandbox)"
  echo "config        : ${WT_CONFIG:-none found (using built-in defaults)}"
  echo "canonical     : ${WT_CANONICAL:-UNSET}"
  echo "sandboxes     : $WT_HOME"
  echo "src dataset   : ${WT_DS_SRC:-UNSET}"
  echo "wt dataset    : ${WT_DS_PARENT:-UNSET}"
  echo "target uid/gid: $WT_TARGET_UID:$WT_TARGET_GID"
  echo "zfs property  : $WT_ZFS_PROP"
  echo "excluded      : ${WT_SNAPSHOT_EXCLUDE:-none}"
  echo "enter hook    : ${WT_HOOK_ENTER:-none}"
  echo "teardown hook : ${WT_HOOK_TEARDOWN:-none}"
  if command -v zfs >/dev/null 2>&1 && [ -n "$WT_DS_SRC" ] && [ -n "$WT_DS_PARENT" ]; then
    local src_ok parent_ok sub
    zfs list -H -o name "$WT_DS_SRC" >/dev/null 2>&1 && src_ok=yes || src_ok='MISSING (host setup not run?)'
    zfs list -H -o name "$WT_DS_PARENT" >/dev/null 2>&1 && parent_ok=yes || parent_ok='MISSING (host setup not run?)'
    echo "src ds        : $src_ok"
    echo "wt ds         : $parent_ok"
    for sub in $WT_SNAPSHOT_EXCLUDE; do
      zfs list -H -o name "$WT_DS_SRC/$sub" >/dev/null 2>&1 \
        && echo "excl ds       : $WT_DS_SRC/$sub  yes" \
        || echo "excl ds       : $WT_DS_SRC/$sub  MISSING"
    done
  elif ! command -v zfs >/dev/null 2>&1; then
    echo "zfs CLI       : NOT INSTALLED"
  fi
  ls "$WT_HOME"/active/* >/dev/null 2>&1 \
    && echo "active        : $(ls "$WT_HOME"/active/ 2>/dev/null | tr '\n' ' ')" \
    || echo "active        : none"
}

wt_ssh_config() {
  local repo="${1:-LOCAL_REPO}"   # this checkout's path on your local machine; the container can't know it
  local caller="${2:-}"           # absolute local path of the wt-ssh generating this config, if any
  local d name proxy
  # The ProxyCommand target, in order: a WT_SSH_PROXY containing a slash is a project that
  # vendors wt-ssh at a checkout-relative path — deliberate config, it wins. Otherwise the
  # absolute path of the wt-ssh that is generating this config (passed through by its `config`
  # verb) is known-good on the local machine whether or not it is on PATH. A bare PATH-looked-up
  # name is the last resort, for hand-run `wt ssh-config`.
  case "$WT_SSH_PROXY" in
    */*) proxy="$repo/$WT_SSH_PROXY" ;;
    *)   proxy="${caller:-$WT_SSH_PROXY}" ;;
  esac
  echo "# --- wt-ssh: paste into ~/.ssh/config on your local machine ---"
  [ "$repo" = LOCAL_REPO ] && \
    echo "# Replace LOCAL_REPO with this checkout's path on your local machine (the source of $WT_CANONICAL)."
  # WT_SSH_REPO is baked into every ProxyCommand: ssh runs it from an arbitrary directory (an
  # editor typically spawns it from $HOME), where wt-ssh could not otherwise tell which checkout
  # — and so which container — the session is for.
  for d in "$WT_HOME"/trees/*/; do
    [ -d "$d" ] || continue
    name=$(basename "$d")
    printf '\nHost wt-%s\n  User %s\n  ProxyCommand env WT_SSH_REPO=%s %s proxy %s\n  StrictHostKeyChecking no\n  UserKnownHostsFile /dev/null\n' \
      "$name" "$WT_TARGET_USER" "$repo" "$proxy" "$name"
  done
}

wt_ssh_setup() {
  mkdir -p "$WT_SSH_DIR"; chmod 700 "$WT_SSH_DIR"
  sudo mkdir -p /run/sshd && sudo chmod 0755 /run/sshd   # sshd privsep dir (lost on container restart)

  cat > "$WT_SSH_DIR/sshd_config" <<EOF
# Generated by 'wt ssh-setup'. Inetd-mode config for wt-ssh (see wt ssh-serve).
HostKey /etc/ssh/ssh_host_ed25519_key
UsePAM yes
PubkeyAuthentication yes
PasswordAuthentication no
KbdInteractiveAuthentication no
AllowUsers $WT_TARGET_USER
AuthorizedKeysFile $WT_SSH_DIR/authorized_keys
ForceCommand $WT_REMOTE_BIN ssh-forced
PermitTTY yes
LogLevel INFO
EOF

  # Authorize the forwarded agent key(s) plus any local pubkeys. This grants no new access: you
  # already need docker to reach the container at all, which is strictly more power.
  #
  # Staged, and moved into place only once it holds a key. A container start that beats the host's
  # agent forwarding finds `ssh-add -L` empty — and if that overwrote authorized_keys in place, it
  # would lock wt-ssh out. Typically run as `wt ssh-setup || true` from a container start hook,
  # where the swallowed exit code would be the only trace.
  local keys="$WT_SSH_DIR/authorized_keys.new"
  { ssh-add -L 2>/dev/null; cat "$HOME"/.ssh/*.pub 2>/dev/null; } \
    | grep -E '^(ssh-|ecdsa-|sk-)' | sort -u > "$keys" || true
  if [ ! -s "$keys" ]; then
    rm -f "$keys"
    die "no public keys found (agent empty and no $HOME/.ssh/*.pub) — add a key and re-run"
  fi
  # Header first, so the file doesn't read as hand-maintained: it is rebuilt on every container
  # start, and a key appended here by hand silently vanishes on the next one.
  printf '%s\n%s\n' \
    "# Generated by 'wt ssh-setup' — rebuilt on container start; add persistent keys as ~/.ssh/*.pub" \
    "$(cat "$keys")" > "$keys"
  chmod 600 "$keys"
  mv -f "$keys" "$WT_SSH_DIR/authorized_keys"

  sudo /usr/sbin/sshd -t -f "$WT_SSH_DIR/sshd_config" \
    || die "generated sshd_config failed 'sshd -t' validation"

  log "wt-ssh ready: $(grep -cE '^(ssh-|ecdsa-|sk-)' "$WT_SSH_DIR/authorized_keys") key(s) authorized in $WT_SSH_DIR"
  log "on your local machine: run 'wt-ssh config' from the checkout and paste it into ~/.ssh/config"
}

# Runs as ROOT (over `docker exec -u0`): inetd sshd needs real privileges to read the host key,
# do privsep, and setuid to the target user. The sandbox name rides in on -o SetEnv, where the
# ForceCommand below picks it up. Validated here so a bad name fails cleanly, before sshd starts.
wt_ssh_serve() {
  local name=${1:?usage: wt ssh-serve <name>}; validate_name "$name"; set_paths "$name"
  [ -d "$tree" ] || die "no sandbox '$name' — run 'wt new $name'"
  exec /usr/sbin/sshd -i -e -o "SetEnv=WT_SANDBOX=$name" -f "$WT_SSH_DIR/sshd_config"
}

# sshd ForceCommand target — runs as the target user, post-auth. Enters the sandbox and runs the
# client's command (SSH hands it over as one string) under a login shell, preserving quoting.
wt_ssh_forced() {
  : "${WT_SANDBOX:?WT_SANDBOX unset (wt ssh-serve must pass -o SetEnv=WT_SANDBOX)}"
  validate_name "$WT_SANDBOX"
  # Only if the install declared one. Pointing SSH_AUTH_SOCK at a socket that isn't there is worse
  # than leaving it alone: it would override a working agent with a dead path.
  [ -n "$WT_SSH_AGENT_SOCK" ] && export SSH_AUTH_SOCK="$WT_SSH_AGENT_SOCK"
  wt_enter "$WT_SANDBOX" -- bash -lc "${SSH_ORIGINAL_COMMAND:-exec bash -l}"
}

usage() { awk 'NR==1{next} /^#/{sub(/^# ?/,""); print; next} {exit}' "${BASH_SOURCE[0]}"; }

# Sourcing wt (test/test-hooks-unit.sh) defines its functions without dispatching a command.
[ "${BASH_SOURCE[0]}" = "$0" ] || return 0

subcmd=${1:-}; shift || true
case "$subcmd" in
  new)       wt_new "$@" ;;
  enter)     wt_enter "$@" ;;
  list)      wt_list "$@" ;;
  rm)        wt_rm "$@" ;;
  gc)        wt_gc "$@" ;;
  status)    wt_status "$@" ;;
  ssh-config) wt_ssh_config "$@" ;;
  ssh-setup)  wt_ssh_setup "$@" ;;
  ssh-serve)  wt_ssh_serve "$@" ;;
  ssh-forced) wt_ssh_forced "$@" ;;
  ''|help|-h|--help) usage ;;
  *) die "unknown command '$subcmd' (try 'wt help')" ;;
esac
