#!/usr/bin/env bash
# wt-ssh <verb> — optional HOST-side entrypoint for `wt` sandboxes. Run this on the machine
# with `docker` access to the container (your laptop). For sandbox commands (new/enter/rm/…)
# run `wt` INSIDE the container; this tool only proxies the SSH-related ones in over docker exec.
#
# It resolves THIS checkout's devcontainer by the bind mount whose destination is $WT_CANONICAL
# (launcher-agnostic — unlike the VS-Code-only devcontainer.local_folder label), then runs the
# matching container-side `wt` subcommand.
#
#   wt-ssh config        print ~/.ssh/config blocks to paste on this machine (one Host wt-<name>
#                        per sandbox); auto-fills this checkout's path
#   wt-ssh list          list sandboxes (proxies `wt list` in the container)
#   wt-ssh proxy <name>  SSH ProxyCommand transport: hand an inetd `sshd -i` session to the ssh
#                        client over docker exec (no listening port). Used by generated config.
#
# This runs on the HOST, so it cannot read the container's /etc/wt/config. It finds the same
# config inside the checkout instead: $WT_SSH_CONFIG, else <repo>/.wt.conf, else
# <repo>/.config/wt.conf. Only three values matter to it (all env-overridable):
#   WT_CANONICAL     the mount destination inside the container — how the container is matched
#   WT_REMOTE_BIN    wt's path inside the container
#   WT_TARGET_USER   the unprivileged user to exec as
#
# Env hooks:
#   WT_SSH_CONTAINER  use this container id, skip resolution
#   WT_SSH_REPO       override the checkout root used for matching (default: this script's repo)
#   WT_SSH_CONFIG     config file to read (default: search the checkout, see above)
#   WT_SSH_DRYRUN     print the resolved `docker exec` argv and exit (for tests)
set -euo pipefail

# The checkout this serves. In order:
#   $WT_SSH_REPO           explicit override; the generated ProxyCommand lines use it, so an ssh
#                          session resolves the same repo whatever directory ssh runs from
#   this script's repo     the vendored case (wt-ssh copied into the consuming repo) — asked of
#                          git rather than counted in `..` levels, because the script's depth
#                          below the repo root is that project's business; taken only when a wt
#                          config is actually there, because an INSTALLED wt-ssh's real path
#                          resolves into the wt checkout itself, which serves no project
#   the caller's repo      the installed-on-PATH case: run `wt-ssh` from inside your project
has_wt_conf() { [ -r "$1/.wt.conf" ] || [ -r "$1/.config/wt.conf" ]; }
here=$(dirname "$(readlink -f "$0")")
self=$(git -C "$here" rev-parse --show-toplevel 2>/dev/null) || self=$(cd "$here/.." && pwd)
if [ -n "${WT_SSH_REPO:-}" ]; then
  repo=$WT_SSH_REPO
elif has_wt_conf "$self"; then
  repo=$self
else
  cwd_repo=$(git rev-parse --show-toplevel 2>/dev/null || true)
  if [ -n "$cwd_repo" ] && has_wt_conf "$cwd_repo"; then repo=$cwd_repo; else repo=$self; fi
fi
repo=$(realpath -m "$repo")

# Environment wins over the config file, same rule as wt.
_env=$(export -p | grep -E '^declare -x WT_[A-Za-z0-9_]+=' || true)
if [ -z "${WT_SSH_CONFIG+x}" ]; then
  for c in "$repo/.wt.conf" "$repo/.config/wt.conf"; do
    [ -r "$c" ] && { WT_SSH_CONFIG=$c; break; }
  done
fi
if [ -n "${WT_SSH_CONFIG:-}" ] && [ -r "$WT_SSH_CONFIG" ]; then
  # shellcheck source=/dev/null
  . "$WT_SSH_CONFIG"
  eval "$_env"
fi

WT_CANONICAL=${WT_CANONICAL:-}
WT_REMOTE_BIN=${WT_REMOTE_BIN:-/usr/local/bin/wt}
WT_TARGET_USER=${WT_TARGET_USER:-$(id -nu)}

usage() {
  cat >&2 <<EOF
usage: wt-ssh <config | list | proxy <name>>   (run on the host; needs docker)
  config         print ~/.ssh/config blocks for this checkout's sandboxes, to paste locally
  list           list this checkout's sandboxes
  proxy <name>   SSH ProxyCommand transport (invoked by generated ~/.ssh/config, not by hand)
For sandbox commands (new/enter/rm/…), run \`wt\` inside the container.
EOF
  exit 2
}

resolve() {
  local c src
  for c in $(docker ps -q); do
    src=$(docker inspect "$c" --format \
      "{{range .Mounts}}{{if eq .Destination \"$WT_CANONICAL\"}}{{.Source}}{{end}}{{end}}" 2>/dev/null)
    [ -n "$src" ] || continue
    [ "$(realpath -m "${src%/}")" = "$repo" ] && { echo "$c"; return 0; }
  done
  return 1
}

resolve_cid() {
  [ -n "$WT_CANONICAL" ] \
    || { echo "wt-ssh: WT_CANONICAL is not set (config: ${WT_SSH_CONFIG:-none found}) — cannot match a container" >&2; exit 1; }
  local cid=${WT_SSH_CONTAINER:-$(resolve || true)}
  [ -n "$cid" ] || { echo "wt-ssh: no running devcontainer whose $WT_CANONICAL is $repo" >&2; exit 1; }
  echo "$cid"
}

verb=${1:-}; shift || true
case "$verb" in
  # The second argument is this script's own absolute path: the generated ProxyCommand lines
  # point back at it, so the ssh transport works whether or not wt-ssh is also on PATH.
  config) cid=$(resolve_cid); set -- docker exec -u "$WT_TARGET_USER" "$cid" "$WT_REMOTE_BIN" ssh-config "$repo" "$(readlink -f "$0")" ;;
  list)   cid=$(resolve_cid); set -- docker exec -u "$WT_TARGET_USER" "$cid" "$WT_REMOTE_BIN" list ;;
  proxy)  name=${1:-}; [ -n "$name" ] || usage; cid=$(resolve_cid)
          set -- docker exec -u0 -i "$cid" "$WT_REMOTE_BIN" ssh-serve "$name" ;;
  *)      usage ;;
esac

if [ -n "${WT_SSH_DRYRUN:-}" ]; then
  echo "$*"
  exit 0
fi
exec "$@"
